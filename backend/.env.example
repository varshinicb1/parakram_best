# ============================================================================
# Parakram Backend — Environment Variables
# Copy this to .env and fill in your values
# ============================================================================

# Supabase PostgreSQL (REQUIRED)
# Get from: Supabase Dashboard → Settings → Database → Connection string
SUPABASE_DB_URL=postgres://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# JWT Secret (REQUIRED)
# Get from: Supabase Dashboard → Settings → API → JWT Settings → JWT Secret
JWT_SECRET=your-supabase-jwt-secret

# LLM Provider (REQUIRED for AI compilation)
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here
LLM_MODEL=mistralai/mistral-7b-instruct

# Email (OPTIONAL — emails log to console without this)
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-key
EMAIL_FROM=noreply@vidyuthlabs.co.in

# Server
HOST=0.0.0.0
PORT=8400
RUST_LOG=parakram_backend=info,tower_http=info

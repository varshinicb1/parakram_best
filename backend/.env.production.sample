# Parakram Platform v1.0.0 Production Configuration
# Copy this file to .env and fill in secure values.

# Database
DATABASE_URL="sqlite:parakram.db?mode=rwc"

# Server Bind Address
BIND_ADDR="0.0.0.0:443"

# TLS / HTTPS Support (Required for Production)
TLS_CERT_PATH="/etc/ssl/certs/parakram.crt"
TLS_KEY_PATH="/etc/ssl/private/parakram.key"

# JSON Web Token Secret
# Must be at least 32 characters, base64url encoded. Do NOT use this sample key in production!
JWT_SECRET="aEltMHFQcGtiZXdtUmlQakNtbWh2S2pZZkxhdWdTSHozQTRoUFNJazBwY2o="

# OpenRouter DeepSeek V3 API Key (for LLM intent parser)
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxx"
